---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang?: "ko" | "en";
}

const { title, description, lang = "ko" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fffaf4" />
    <link rel="icon" href={`${base}/logo-choomboot.svg`} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
